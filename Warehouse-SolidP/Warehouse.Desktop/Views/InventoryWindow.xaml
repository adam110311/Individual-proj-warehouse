<Window x:Class="Warehouse.Desktop.Views.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IT Warehouse - Inventory"
        Width="950" Height="550"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search / filter bar -->
        <Grid Grid.Row="0" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Padding="4" Margin="0,0,8,0"/>

            <TextBlock Grid.Column="2" Text="Category:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox Grid.Column="3" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategoryFilter}" Padding="4" Margin="0,0,8,0"/>

            <TextBlock Grid.Column="4" Text="Status:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox Grid.Column="5" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatusFilter}" Padding="4" Margin="0,0,8,0"/>

            <Button Grid.Column="6" Content="Search" Command="{Binding SearchCommand}" Padding="12,4"/>
        </Grid>

        <!-- Main: DataGrid + side buttons -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Margin="8,0,0,0"
                      MouseDoubleClick="DataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"       Binding="{Binding I_ID}"          Width="50"/>
                    <DataGridTextColumn Header="Name"     Binding="{Binding Name}"          Width="*"/>
                    <DataGridTextColumn Header="Brand"    Binding="{Binding Brand}"         Width="100"/>
                    <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}"  Width="110"/>
                    <DataGridTextColumn Header="Serial"   Binding="{Binding SerialNumber}"  Width="140"/>
                    <DataGridTextColumn Header="Status"   Binding="{Binding Status}"        Width="90"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Column="1" Margin="8" VerticalAlignment="Top">
                <Button Content="Add"    Command="{Binding AddItemCommand}"    Padding="8,6" Margin="0,0,0,6"/>
                <Button Content="Edit"   Command="{Binding EditItemCommand}"   Padding="8,6" Margin="0,0,0,6"/>
                <Button Content="Delete" Command="{Binding DeleteItemCommand}" Padding="8,6" Margin="0,0,0,6"/>
            </StackPanel>
        </Grid>

        <!-- Bottom bar -->
        <Grid Grid.Row="2" Margin="8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Open Orders" Command="{Binding OpenOrdersCommand}" Padding="12,4"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Foreground="Gray"/>
        </Grid>
    </Grid>
</Window>
