<Window x:Class="Warehouse.Desktop.Views.OrderDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Order Detail"
        Width="700" Height="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Order info -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Order ID:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding O_ID}" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Type:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding OrderType}" Margin="0,0,0,4"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Status:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Status}" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="Reference:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Reference}" Margin="0,0,0,4"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Created:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CreatedDate, StringFormat=yyyy-MM-dd HH:mm}" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="Completed:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding CompletedDate, StringFormat=yyyy-MM-dd HH:mm, TargetNullValue='-'}" Margin="0,0,0,4"/>
        </Grid>

        <TextBlock Grid.Row="1" Text="Items" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>

        <!-- Items list -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"       Binding="{Binding I_ID}"          Width="50"/>
                <DataGridTextColumn Header="Name"     Binding="{Binding Name}"          Width="*"/>
                <DataGridTextColumn Header="Brand"    Binding="{Binding Brand}"         Width="90"/>
                <DataGridTextColumn Header="Serial"   Binding="{Binding SerialNumber}"  Width="130"/>
                <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}"  Width="100"/>
                <DataGridTextColumn Header="Status"   Binding="{Binding Status}"        Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
