<Window x:Class="Warehouse.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IT Warehouse — Login"
        Width="400" Height="280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Sign in"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Email" FontSize="12" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="4"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Password" FontSize="12" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox" FontSize="13" Padding="4"/>
        </StackPanel>

        <TextBlock Grid.Row="3"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <Button Grid.Row="4"
                Content="Login"
                HorizontalAlignment="Right"
                Padding="16,6"
                Click="LoginButton_Click"/>
    </Grid>
</Window>
