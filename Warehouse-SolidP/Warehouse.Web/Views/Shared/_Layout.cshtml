<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IT Warehouse</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
          rel="stylesheet" />
    <style>
        .stat-card {
            border-left: 4px solid #0d6efd;
            background: #f8f9fa;
        }
        .stat-card .stat-value {
            font-size: 2rem;
            font-weight: 600;
        }
        .stat-card .stat-label {
            color: #6c757d;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .stat-card.in-stock   { border-left-color: #198754; }
        .stat-card.dispatched { border-left-color: #6c757d; }
        .stat-card.defective  { border-left-color: #dc3545; }
        .stat-card.pending    { border-left-color: #ffc107; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">IT Warehouse</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-controller="Home" asp-action="Index">Dashboard</a>
                <a class="nav-link" asp-controller="Inventory" asp-action="Index">Inventory</a>
                <a class="nav-link" asp-controller="Analytics" asp-action="Index">Analytics</a>
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <footer class="container mt-5 mb-3">
        <hr />
        <p class="text-muted small">IT Warehouse Management System</p>
    </footer>
</body>
</html>
