@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<h4 class="mb-4">Dashboard</h4>

<!-- Status cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card rounded p-3">
            <div class="stat-value">@Model.TotalItems</div>
            <div class="stat-label">Total Items</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card in-stock rounded p-3">
            <div class="stat-value">@Model.InStockCount</div>
            <div class="stat-label">In Stock</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card dispatched rounded p-3">
            <div class="stat-value">@Model.DispatchedCount</div>
            <div class="stat-label">Dispatched</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card defective rounded p-3">
            <div class="stat-value">@Model.DefectiveCount</div>
            <div class="stat-label">Defective</div>
        </div>
    </div>
</div>

@if (Model.PendingCount > 0)
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card pending rounded p-3">
                <div class="stat-value">@Model.PendingCount</div>
                <div class="stat-label">Pending (Inbound)</div>
            </div>
        </div>
    </div>
}

<!-- Items by category -->
<h5 class="mb-3">Items by Category</h5>

@if (Model.ItemsByCategory.Any())
{
    <table class="table table-sm table-striped" style="max-width: 500px;">
        <thead>
            <tr>
                <th>Category</th>
                <th class="text-end">Count</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cat in Model.ItemsByCategory)
            {
                <tr>
                    <td>@cat.CategoryName</td>
                    <td class="text-end">@cat.Count</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No items in inventory yet.</p>
}
